import torch
from transformers import AutoTokenizer, AutoModelForCausalLM
from peft import PeftModel

def load_model(base_id: str, lora_path: str):
    tokenizer = AutoTokenizer.from_pretrained(lora_path, trust_remote_code=True)
    if tokenizer.pad_token is None:
        tokenizer.pad_token = tokenizer.eos_token

    print(f"[EVAL] CUDA available: {torch.cuda.is_available()}")
    if torch.cuda.is_available():
        print(f"[EVAL] CUDA_VISIBLE_DEVICES={os.environ.get('CUDA_VISIBLE_DEVICES')}")
        print(f"[EVAL] Using device: cuda:0")
        device = torch.device("cuda:0")
        base = AutoModelForCausalLM.from_pretrained(
            base_id,
            torch_dtype=torch.bfloat16,
            device_map=None,
            trust_remote_code=True,
        ).to(device)
    else:
        print("[EVAL] Using device: cpu")
        device = torch.device("cpu")
        base = AutoModelForCausalLM.from_pretrained(
            base_id,
            torch_dtype=torch.float32,
            device_map=None,
            trust_remote_code=True,
        ).to(device)

    # Р’РђР–РќРћ: СЂР°Р·РјРµСЂ СЌРјР±РµРґРґРёРЅРіРѕРІ РїРѕРґ С‚РѕРєРµРЅР°Р№Р·РµСЂ LoRA
    base.resize_token_embeddings(len(tokenizer))

    model = PeftModel.from_pretrained(base, lora_path)
    model.eval()

    # РќР° РІСЃСЏРєРёР№ СЃР»СѓС‡Р°Р№
    model.to(device)

    # Р›РѕРі СѓСЃС‚СЂРѕР№СЃС‚РІР°
